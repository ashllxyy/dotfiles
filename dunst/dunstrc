[global]
    font = JetBrainsMono Nerd Font 9
    line_height = 6
    frame_width = 1
    gap_size = 4
    frame_color = "#333333"
    corner_radius = 4

[urgency_low]
    background = "#000000"
    foreground = "#888888" 
    timeout = 4

[urgency_normal]
    background = "#000000"
    foreground = "#FFFFFF" 
    timeout = 6

[urgency_critical]
    background = "#000000"
    foreground = "#FF0000" 
    frame_color = "#931d00" 
    timeout = 0            
